<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.DishMapper">
    <update id="updateDishInfo">
        update dish
        <set>
            <if test="status!=null">status=#{status},</if>
            <if test="name!=null and name!=''">name=#{name},</if>
            <if test="categoryId!=null">category_id=#{categoryId},</if>
            <if test="price!=null">price=#{price},</if>
            <if test="image!=null and image!=''">image=#{image},</if>
            <if test="description!=null and description!=''">description=#{description},</if>
        </set>
        where id=#{id}
    </update>
    <delete id="deleteDish">
        delete from dish where id in <foreach collection="ids" item="id" separator="," open="(" close=")">
        #{id}
    </foreach>
    </delete>

    <select id="pageQuery" resultType="com.sky.vo.DishVO">
        select d.*,c.name as categoryName from dish d left join category c on d.category_id=c.id
        <where>
            <if test="name!=null and name!=''">
                and d.name=#{name}
            </if>
            <if test="status!=null">
                and c.status=#{status}
            </if>
            <if test="categoryId!=null">
                and c.id=#{categoryId}
            </if>
        </where>
    </select>
    <select id="getDishById" resultType="com.sky.vo.DishVO">
        select d.* from dish d where id=#{id}
    </select>
</mapper>
